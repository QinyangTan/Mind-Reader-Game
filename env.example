# Optional production leaderboard/profile backend.
# Leave empty to use this app's same-origin /api backend with browser-local fallback.
NEXT_PUBLIC_MIND_READER_BACKEND_URL=

# Set to "local" to skip the same-origin/remote backend and use browser-local rankings only.
NEXT_PUBLIC_MIND_READER_BACKEND_MODE=

# Same-origin leaderboard storage.
# Leave empty for memory fallback. Set to "memory" to force memory even if Redis env vars exist.
MIND_READER_LEADERBOARD_STORAGE=

# Durable leaderboard/profile storage via Upstash Redis REST.
# Vercel KV / Upstash integrations usually provide these names automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional aliases if you prefer project-specific names.
MIND_READER_REDIS_REST_URL=
MIND_READER_REDIS_REST_TOKEN=
MIND_READER_REDIS_PREFIX=

# Privacy-safe product analytics.
# Supported modes: empty/no-op, "console", or "http" with an endpoint below.
NEXT_PUBLIC_MIND_READER_ANALYTICS_MODE=
NEXT_PUBLIC_MIND_READER_ANALYTICS_ENDPOINT=
